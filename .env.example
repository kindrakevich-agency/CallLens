# =============================================================================
# CallLens — environment template. Copy to .env and adjust.
# `docker compose up` works with these defaults (AI providers are mocked).
# Secrets must never be committed. In prod, use the Symfony secrets vault.
# =============================================================================

# --- App ---------------------------------------------------------------------
APP_ENV=dev
APP_SECRET=change_me_in_prod_use_a_32+_char_random_string
APP_URL=http://localhost:8081            # API public base (Nginx)
WEB_URL=http://localhost:3001            # Next.js (landing/docs/cabinet)
# Host ports published in dev (change if already in use):
API_PORT=8081
WEB_PORT=3001

# --- Database (PostgreSQL 17 + pgvector) -------------------------------------
POSTGRES_DB=callens
POSTGRES_USER=callens
POSTGRES_PASSWORD=callens
# Used by the Symfony app (host `db` is the compose service name):
DATABASE_URL=postgresql://callens:callens@db:5432/callens?serverVersion=17&charset=utf8

# --- Redis -------------------------------------------------------------------
REDIS_URL=redis://redis:6379

# --- Messenger ---------------------------------------------------------------
# Separate transports so a slow STT provider can't starve scoring/embeddings.
MESSENGER_TRANSPORT_DSN=redis://redis:6379/messages
MESSENGER_TRANSCRIBE_DSN=redis://redis:6379/transcribe
MESSENGER_FAILED_DSN=doctrine://default?queue_name=failed

# --- Object storage (S3) — MinIO in dev, Hetzner Object Storage in prod ------
S3_ENDPOINT=http://minio:9000
S3_REGION=us-east-1
S3_BUCKET=callens-audio
S3_KEY=callens
S3_SECRET=callens-secret
S3_USE_PATH_STYLE=true

# --- AI providers ------------------------------------------------------------
# `fake` runs the whole pipeline deterministically with no paid calls.
AI_STT_PROVIDER=fake                      # deepgram|assemblyai|gladia|fake
AI_LLM_PROVIDER=fake                      # openai|gemini|anthropic|fake
AI_EMBEDDINGS_PROVIDER=fake               # openai|voyage|fake
EMBEDDING_DIM=1024
DEEPGRAM_API_KEY=
DEEPGRAM_MODEL=nova-3
OPENAI_API_KEY=
OPENAI_LLM_MODEL=gpt-4o-mini
OPENAI_EMBEDDING_MODEL=text-embedding-3-large

# --- Auth --------------------------------------------------------------------
JWT_PASSPHRASE=change_me
JWT_ACCESS_TOKEN_TTL=900                  # seconds (15 min)
JWT_REFRESH_TOKEN_TTL=2592000             # seconds (30 days)
COOKIE_DOMAIN=localhost
COOKIE_SECURE=false                       # true in prod (HTTPS)
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=

# --- Mail (Mailpit in dev) ---------------------------------------------------
MAILER_DSN=smtp://mailpit:1025
MAIL_FROM=no-reply@calllens.app

# --- Audio retention ---------------------------------------------------------
AUDIO_RETENTION_MODE=keep                 # keep|delete_after_processing|delete_after_days
AUDIO_RETENTION_DAYS=30

# --- Cube (analytics) --------------------------------------------------------
CUBEJS_API_SECRET=dev_cube_secret_change_me
CUBEJS_DEV_MODE=true

# CORS — regex of allowed SPA origin (credentials enabled)
CORS_ALLOW_ORIGIN=^https?://localhost:3001$

# Cabinet (browser) → API base
NEXT_PUBLIC_API_URL=http://localhost:8081

# Cube API (internal, from the api container)
CUBE_URL=http://cube:4000
